# Application Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-here

# Database Configuration
DATABASE_URL=sqlite:///students.db
# For PostgreSQL: postgresql://user:password@localhost:5432/student_management

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
WORKERS=4

# Logging
LOG_LEVEL=INFO

# API Configuration
API_RATE_LIMIT=100
API_TIMEOUT=60

# Security
DEBUG=False
TESTING=False